VITE_APP_TITLE=智能中台建模平台

# API 前缀（开发环境建议保持 /api，由 Vite 代理到网关；生产环境建议由 Nginx/Ingress 转发 /api -> Gateway）
VITE_API_BASE_URL=/api

# python-data-service（8086）前缀
VITE_PYANALYSIS_URL=/pyanalysis

# FastAPI 主节点（经 Gateway /algo）前缀（推荐：/api/algo）
VITE_BEFORE_URL=/api/algo

# Router base
VITE_BASE_URL=/

# dev proxy targets
VITE_API_TARGET=http://localhost:8080
VITE_PYANALYSIS_TARGET=http://localhost:8086

VITE_DEBUG=true

